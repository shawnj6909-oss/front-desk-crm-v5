# Copy this to .env.local and fill in your credentials

# Get these from your Supabase project:
# 1. SUPABASE_URL: Settings → API → Project URL
# 2. SUPABASE_ANON_KEY: Settings → API → anon (public) key
# 3. SUPABASE_SERVICE_ROLE_KEY: Settings → API → service_role key (if needed)

SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
